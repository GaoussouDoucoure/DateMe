@{
}

@model Application

<h2>Confirm Deletion</h2>
<h3>@Model.LastName, @Model.FirstName</h3>

<form method="post">

    <input type="hidden" asp-for="ApplicationId" /> @* So we can receive the appId that comes through the View to delete*@

    <button type="submit">Delete</button>
    <a class="btn btn-info" asp-controller="Home" asp-action="Waitlist">Cancel</a> @*will return to waitlist page*@
</form>